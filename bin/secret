#!/usr/bin/env bash
#
# secret - a friendly wrapper around macOS's `security` CLI for doing CRUD on
# generic-password secrets (API keys, tokens, PATs) in the Apple Keychain.
#
# Usage:
#   secret set <name>       Create or update a secret (hidden prompt, or piped stdin)
#   secret get <name>       Print a secret's value to stdout (e.g. for ~/.localrc)
#   secret rotate <name>    Replace an existing secret's value (confirms overwrite)
#   secret rm <name>        Delete a secret
#   secret help             Show this help
#
# The account defaults to $USER (override with $SECRET_ACCOUNT) and the service
# is <name>, matching `security ... -a "$USER" -s <name>`, so existing secrets
# stored that way remain reachable. Example:
#
#   secret set snyk_api_key
#   export SNYK_TOKEN=$(secret get snyk_api_key)   # in ~/.localrc
#   secret rotate github_pat                        # paste a freshly-rotated PAT

set -euo pipefail
IFS=$'\n\t'

account="${SECRET_ACCOUNT:-$USER}"

exit_with_error() {
    echo "ERROR: $1" >&2
    exit 1
}

usage() {
    awk 'NR<3{next} /^#/{sub(/^# ?/,""); print; next} {exit}' "$0"
}

# Read a secret value: hidden prompt when interactive, otherwise from stdin.
read_value() {
    local prompt="$1" value
    if [ -t 0 ]; then
        read -rs -p "$prompt" value
        echo >&2
    else
        IFS= read -r value || true
    fi
    [ -n "$value" ] || exit_with_error "empty value; nothing stored"
    printf '%s' "$value"
}

secret_exists() {
    security find-generic-password -a "$account" -s "$1" -w >/dev/null 2>&1
}

cmd_set() {
    local name="${1:-}"
    [ -n "$name" ] || exit_with_error "usage: secret set <name>"
    local value
    value="$(read_value "New value for '$name': ")"
    security add-generic-password -a "$account" -s "$name" -w "$value" -U \
        || exit_with_error "failed to store '$name' for account '$account'"
    echo "Stored '$name' for account '$account'."
}

cmd_get() {
    local name="${1:-}"
    [ -n "$name" ] || exit_with_error "usage: secret get <name>"
    security find-generic-password -a "$account" -s "$name" -w 2>/dev/null \
        || exit_with_error "no secret named '$name' for account '$account'"
}

cmd_rotate() {
    local name="${1:-}"
    [ -n "$name" ] || exit_with_error "usage: secret rotate <name>"
    secret_exists "$name" \
        || exit_with_error "no secret named '$name' to rotate (use 'secret set' to create it)"
    local value
    value="$(read_value "New value for '$name' (rotating): ")"
    security add-generic-password -a "$account" -s "$name" -w "$value" -U \
        || exit_with_error "failed to rotate '$name' for account '$account'"
    echo "Rotated '$name' for account '$account'."
}

cmd_rm() {
    local name="${1:-}"
    [ -n "$name" ] || exit_with_error "usage: secret rm <name>"
    security delete-generic-password -a "$account" -s "$name" >/dev/null 2>&1 \
        || exit_with_error "no secret named '$name' for account '$account'"
    echo "Deleted '$name' for account '$account'."
}

main() {
    local sub="${1:-help}"
    [ "$#" -gt 0 ] && shift || true
    case "$sub" in
        set)            cmd_set "$@" ;;
        get)            cmd_get "$@" ;;
        rotate)         cmd_rotate "$@" ;;
        rm|delete)      cmd_rm "$@" ;;
        help|-h|--help) usage ;;
        *)              usage >&2; exit_with_error "unknown subcommand: $sub" ;;
    esac
}

main "$@"
