# DO NOT RENAME THIS FILE
# unless you enjoy infinite loops

export DOTFILES="$HOME/.local/share/chezmoi"

# cache the output of `eval "$(cmd ...)"` style init hooks and source the
# cached file instead; regenerate only when the tool's binary is newer than
# the cache, so the warm path costs zero forks
_zsh_cache=${XDG_CACHE_HOME:-$HOME/.cache}/zsh
cached-eval() {
  local name=$1 bin
  shift
  if [[ $1 == */* ]]; then
    bin=$1
  else
    bin=$commands[$1]
  fi
  [[ -x $bin ]] || return 0
  local cache=$_zsh_cache/$name.zsh
  if [[ ! -s $cache || $bin -nt $cache ]]; then
    mkdir -p $_zsh_cache
    "$@" > $cache
  fi
  source $cache
}

# declare an array of our .zsh files
# -U removes duplicate values
typeset -U config_files
config_files=($DOTFILES/*/*.zsh)

# load the exports files
for file in ${(M)config_files:#*/exports.zsh}; do
  source "$file"
done

# load the path files
for file in ${(M)config_files:#*/path.zsh}; do
  source "$file"
done

# Configure & load the prompt theme, sindresorhus/pure
source $DOTFILES/zsh/prompt.zsh

# load plugins without a plugin manager
# they are fetched and refreshed by chezmoi (see .chezmoiexternal.yaml)
# inspiration taken from https://github.com/mattmc3/zsh_unplugged
ZPLUGINDIR=$HOME/.local/zsh-plugins
source $ZPLUGINDIR/zsh-autosuggestions/zsh-autosuggestions.plugin.zsh
source $ZPLUGINDIR/zsh-completions/zsh-completions.plugin.zsh
# N.B.: Load syntax highlighting *before* history search. Cf. https://github.com/zsh-users/zsh-history-substring-search#usage
source $ZPLUGINDIR/zsh-syntax-highlighting/zsh-syntax-highlighting.plugin.zsh
source $ZPLUGINDIR/zsh-history-substring-search/zsh-history-substring-search.plugin.zsh
source $ZPLUGINDIR/zsh-z/zsh-z.plugin.zsh

# load everything but the path, exports, and prompt files
# (prompt.zsh was already sourced above; sourcing it again would run
# promptinit/prompt pure twice)
for file in ${${${config_files:#*/path.zsh}:#*/exports.zsh}:#*/prompt.zsh}; do
  source "$file"
done

# keybinds for zsh-autosuggestion plugih
# Cf. https://github.com/zsh-users/zsh-autosuggestions/?tab=readme-ov-file#key-bindings
# bind control + space to accept the suggestion
# this saves round trips to the right arrow (or END) keys
bindkey '^ ' autosuggest-accept
# Currently not bound: accept and execute autosuggestion
# bindkey 'KEYBINDING' autosuggest-execute

# initialize autocomplete here, otherwise functions won't be loaded
# only regenerate the dump once every 24h; otherwise skip the security
# check (-C) to speed up interactive shell startup
autoload -Uz compinit
# glob the dump into an array (filename generation doesn't happen inside [[ ]]),
# then count matches: >0 means the dump is older than 24h and should be rebuilt
_zdump=(${HOME}/.zcompdump(#qN.mh+24))
if (( ${#_zdump} )); then
  compinit
else
  compinit -C
fi
unset _zdump

unset config_files

# top secret
if [[ -a $HOME/.localrc ]]
then
  source $HOME/.localrc
fi

# Fixes wonky control flow issues
stty -ixon -ixoff

# zprof
