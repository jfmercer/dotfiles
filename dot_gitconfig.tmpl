[user]
    name = John F. Mercer
    email = {{ .email }}

[color]
    branch = true
    diff = true
    grep = true
    interactive = true
    status = true
    ui = true

[color "branch"]
    current = yellow reverse
    local = yellow
    remote = green

[color "diff-highlight"]
    oldNormal = red bold
    oldHighlight = red bold 52
    newNormal = green bold
    newHighlight = green bold 22

[color "diff"]
    meta = 227
    frag = magenta bold
    commit = 227 bold
    old = red bold
    new = green bold
    whitespace = red reverse

[color "interactive"]
    error = red bold

[color "status"]
    added = yellow
    changed = green
    untracked = red
    branch = magenta

[core]
    excludesfile = ~/.gitignore
    editor = vim
    ignorecase = false
    # the default is 'less -FRSX'
    pager = delta --diff-so-fancy
    autocrlf = input

[delta]
    navigate = true
    line-numbers = true
    # side-by-side = true

[diff]
    colorMoved = default

# Any git pull or git fetch will auto-prune, that is, any local branch whose
# corresponding remote is gone will be deleted.
[fetch]
    prune = true

[interactive]
    diffFilter = delta --color-only

[merge]
    # zdiff3 (Git 2.35+) is a strictly better diff3
    conflictStyle = zdiff3

[push]
    # This is the default in Git 2.0
    default = simple
    # Auto-create the upstream branch on first push (Git 2.37+)
    autoSetupRemote = true
{{- if get . "work" }}

# Work only: rewrite Hagerty Azure DevOps HTTPS remotes to SSH.
[url "git@ssh.dev.azure.com:v3/hagerty/Hagerty/"]
    insteadOf = https://hagerty@dev.azure.com/hagerty/Hagerty/_git/
{{- end }}
